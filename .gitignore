# 忽略根目录所有内容
/*

# 保留 .gitignore
!/.gitignore

# 保留 backend
!/backend/
!/backend/**

# 保留 fronted 文件夹本身
!/fronted/

# 忽略 fronted 下所有内容
/fronted/*

# 只保留 fronted/dist
!/fronted/dist/
!/fronted/dist/**

# 后端 Maven 编译输出不上传
/backend/target/
/backend/**/*.class

# 日志、临时文件
*.log
*.tmp
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml
.codex/
.agents/