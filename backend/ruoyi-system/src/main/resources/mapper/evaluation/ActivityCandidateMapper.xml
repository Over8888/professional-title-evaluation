<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.evaluation.mapper.ActivityCandidateMapper">
    <resultMap type="ActivityCandidate" id="ActivityCandidateResult">
        <id property="id" column="id" />
        <result property="activityId" column="activity_id" />
        <result property="candidateId" column="candidate_id" />
        <result property="sourceType" column="source_type" />
        <result property="sourceActivityId" column="source_activity_id" />
        <result property="sourceActivityCandidateId" column="source_activity_candidate_id" />
        <result property="importSeq" column="import_seq" />
        <result property="name" column="name" />
        <result property="gender" column="gender" />
        <result property="birthDate" column="birth_date" />
        <result property="education" column="education" />
        <result property="company" column="company" />
        <result property="firstLevelDepartment" column="first_level_department" />
        <result property="department" column="department" />
        <result property="thirdLevelDepartment" column="third_level_department" />
        <result property="position" column="position" />
        <result property="idCard" column="id_card" />
        <result property="currentLevel" column="current_level" />
        <result property="appliedLevel" column="applied_level" />
        <result property="fixedType" column="fixed_type" />
        <result property="lastYearAssessment" column="last_year_assessment" />
        <result property="evaluationScore" column="evaluation_score" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <resultMap type="Candidate" id="CandidateSnapshotResult">
        <id property="id" column="id" />
        <result property="activityId" column="activity_id" />
        <result property="candidateId" column="candidate_id" />
        <result property="sourceType" column="source_type" />
        <result property="sourceActivityId" column="source_activity_id" />
        <result property="sourceActivityCandidateId" column="source_activity_candidate_id" />
        <result property="importSeq" column="import_seq" />
        <result property="name" column="name" />
        <result property="gender" column="gender" />
        <result property="birthDate" column="birth_date" />
        <result property="education" column="education" />
        <result property="company" column="company" />
        <result property="firstLevelDepartment" column="first_level_department" />
        <result property="department" column="department" />
        <result property="thirdLevelDepartment" column="third_level_department" />
        <result property="position" column="position" />
        <result property="idCard" column="id_card" />
        <result property="currentLevel" column="current_level" />
        <result property="appliedLevel" column="applied_level" />
        <result property="fixedType" column="fixed_type" />
        <result property="lastYearAssessment" column="last_year_assessment" />
        <result property="evaluationScore" column="evaluation_score" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectActivityCandidateVo">
        select id, activity_id, candidate_id, source_type, source_activity_id, source_activity_candidate_id,
               import_seq, name, gender, birth_date, education, company, first_level_department, department,
               third_level_department, position, id_card, current_level, applied_level, fixed_type,
               last_year_assessment, evaluation_score, create_by, create_time, update_by, update_time
        from ActivityCandidate
    </sql>

    <sql id="candidateRangeOrderBy">
        order by case department
                   when '船体组' then 1
                   when '船机组' then 2
                   when '船电组' then 3
                   when '综合组' then 4
                   else 99
                 end asc,
                 department asc,
                 case applied_level
                   when '正高级' then 1
                   when '正高级工程师' then 1
                   when '副高级' then 2
                   when '高级工程师' then 2
                   when '中级' then 3
                   when '工程师' then 3
                   when '初级' then 4
                   when '助理工程师' then 4
                   when '员级' then 5
                   when '技术员' then 5
                   else 99
                 end asc,
                 applied_level asc,
                 import_seq asc,
                 id asc
    </sql>

    <sql id="activityCandidateFilters">
        <where>
            <if test="activityId != null">and activity_id = #{activityId}</if>
            <if test="candidateId != null">and candidate_id = #{candidateId}</if>
            <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="company != null and company != ''">and company like concat('%', #{company}, '%')</if>
            <if test="firstLevelDepartment != null and firstLevelDepartment != ''">and first_level_department = #{firstLevelDepartment}</if>
            <if test="department != null and department != ''">and department = #{department}</if>
            <if test="thirdLevelDepartment != null and thirdLevelDepartment != ''">and third_level_department = #{thirdLevelDepartment}</if>
            <if test="position != null and position != ''">and position = #{position}</if>
            <if test="currentLevel != null and currentLevel != ''">and current_level = #{currentLevel}</if>
            <if test="appliedLevel != null and appliedLevel != ''">and applied_level = #{appliedLevel}</if>
            <if test="fixedType != null and fixedType != ''">and fixed_type = #{fixedType}</if>
        </where>
    </sql>

    <select id="selectActivityCandidateList" parameterType="ActivityCandidate" resultMap="ActivityCandidateResult">
        <include refid="selectActivityCandidateVo"/>
        <include refid="activityCandidateFilters"/>
        <include refid="candidateRangeOrderBy"/>
    </select>

    <select id="selectCandidateSnapshotList" parameterType="Candidate" resultMap="CandidateSnapshotResult">
        <include refid="selectActivityCandidateVo"/>
        <include refid="activityCandidateFilters"/>
        <include refid="candidateRangeOrderBy"/>
    </select>

    <select id="selectActivityCandidateById" parameterType="Long" resultMap="ActivityCandidateResult">
        <include refid="selectActivityCandidateVo"/> where id = #{id}
    </select>

    <select id="selectActivityCandidateByActivityIdAndIdCard" parameterType="ActivityCandidate" resultMap="ActivityCandidateResult">
        <include refid="selectActivityCandidateVo"/>
        where activity_id = #{activityId}
        <if test="idCard != null and idCard != ''">and id_card = #{idCard}</if>
        limit 1
    </select>

    <select id="selectActivityCandidateByActivityIdAndScope" parameterType="ActivityCandidate" resultMap="ActivityCandidateResult">
        <include refid="selectActivityCandidateVo"/>
        where activity_id = #{activityId}
          and department = #{department}
          and applied_level = #{appliedLevel}
          and id_card = #{idCard}
        limit 1
    </select>

    <select id="selectAllCandidatesByActivityId" parameterType="Long" resultMap="ActivityCandidateResult">
        <include refid="selectActivityCandidateVo"/>
        where activity_id = #{activityId}
        <include refid="candidateRangeOrderBy"/>
    </select>

    <select id="selectVoteCandidatesByActivityId" parameterType="Long" resultMap="ActivityCandidateResult">
        <include refid="selectActivityCandidateVo"/>
        where activity_id = #{activityId} and fixed_type = 'VOTE'
        <include refid="candidateRangeOrderBy"/>
    </select>

    <select id="countVoteCandidatesByActivityId" parameterType="Long" resultType="int">
        select count(1) from ActivityCandidate where activity_id = #{activityId} and fixed_type = 'VOTE'
    </select>

    <select id="countActivityCandidateByActivityId" parameterType="Long" resultType="int">
        select count(1) from ActivityCandidate where activity_id = #{activityId}
    </select>

    <select id="countUnconfirmedByActivityId" parameterType="Long" resultType="int">
        select count(1) from ActivityCandidate where activity_id = #{activityId} and (fixed_type is null or fixed_type = '')
    </select>

    <insert id="insertActivityCandidate" parameterType="ActivityCandidate" useGeneratedKeys="true" keyProperty="id">
        insert into ActivityCandidate(activity_id, candidate_id, source_type, source_activity_id, source_activity_candidate_id,
                                      import_seq, name, gender, birth_date, education, company, first_level_department, department,
                                      third_level_department, position, id_card, current_level, applied_level, fixed_type,
                                      last_year_assessment, evaluation_score, create_by, create_time)
        values(#{activityId}, #{candidateId}, #{sourceType}, #{sourceActivityId}, #{sourceActivityCandidateId},
               #{importSeq}, #{name}, #{gender}, #{birthDate}, #{education}, #{company}, #{firstLevelDepartment}, #{department},
               #{thirdLevelDepartment}, #{position}, #{idCard}, #{currentLevel}, #{appliedLevel}, #{fixedType},
               #{lastYearAssessment}, #{evaluationScore}, #{createBy}, sysdate())
    </insert>

    <update id="updateActivityCandidate" parameterType="ActivityCandidate">
        update ActivityCandidate
        <set>
            <if test="activityId != null">activity_id = #{activityId},</if>
            <if test="candidateId != null">candidate_id = #{candidateId},</if>
            <if test="sourceType != null">source_type = #{sourceType},</if>
            <if test="sourceActivityId != null">source_activity_id = #{sourceActivityId},</if>
            <if test="sourceActivityCandidateId != null">source_activity_candidate_id = #{sourceActivityCandidateId},</if>
            <if test="importSeq != null">import_seq = #{importSeq},</if>
            <if test="name != null">name = #{name},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthDate != null">birth_date = #{birthDate},</if>
            <if test="education != null">education = #{education},</if>
            <if test="company != null">company = #{company},</if>
            <if test="firstLevelDepartment != null">first_level_department = #{firstLevelDepartment},</if>
            <if test="department != null">department = #{department},</if>
            <if test="thirdLevelDepartment != null">third_level_department = #{thirdLevelDepartment},</if>
            <if test="position != null">position = #{position},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="currentLevel != null">current_level = #{currentLevel},</if>
            <if test="appliedLevel != null">applied_level = #{appliedLevel},</if>
            <if test="fixedType != null">fixed_type = #{fixedType},</if>
            <if test="lastYearAssessment != null">last_year_assessment = #{lastYearAssessment},</if>
            <if test="evaluationScore != null">evaluation_score = #{evaluationScore},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <update id="updateCandidateSnapshot" parameterType="Candidate">
        update ActivityCandidate
        <set>
            <if test="fixedType != null">fixed_type = #{fixedType},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteActivityCandidateByActivityId" parameterType="Long">
        delete from ActivityCandidate where activity_id = #{activityId}
    </delete>
</mapper>
