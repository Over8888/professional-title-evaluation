<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.evaluation.mapper.ExportJobMapper">
    <resultMap type="ExportJob" id="ExportJobResult">
        <id property="id" column="id" />
        <result property="activityId" column="activity_id" />
        <result property="jobType" column="job_type" />
        <result property="exportType" column="export_type" />
        <result property="status" column="status" />
        <result property="fileName" column="file_name" />
        <result property="fileUrl" column="file_url" />
        <result property="generatedBy" column="generated_by" />
        <result property="generatedAt" column="generated_at" />
        <result property="errorMessage" column="error_message" />
    </resultMap>
    <sql id="selectExportJobVo">select id, activity_id, job_type, export_type, status, file_name, file_url, generated_by, generated_at, error_message from ExportJob</sql>
    <select id="selectExportJobList" parameterType="ExportJob" resultMap="ExportJobResult">
        <include refid="selectExportJobVo"/>
        <where>
            <if test="activityId != null">and activity_id = #{activityId}</if>
            <if test="jobType != null and jobType != ''">and job_type = #{jobType}</if>
            <if test="exportType != null and exportType != ''">and export_type = #{exportType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by id desc
    </select>
    <select id="selectExportJobById" parameterType="Long" resultMap="ExportJobResult"><include refid="selectExportJobVo"/> where id = #{id}</select>
    <insert id="insertExportJob" parameterType="ExportJob" useGeneratedKeys="true" keyProperty="id">
        insert into ExportJob(activity_id, job_type, export_type, status, file_name, file_url, generated_by, generated_at, error_message)
        values(#{activityId}, #{jobType}, #{exportType}, #{status}, #{fileName}, #{fileUrl}, #{generatedBy}, sysdate(), #{errorMessage})
    </insert>
    <update id="updateExportJob" parameterType="ExportJob">
        update ExportJob
        <set>
            <if test="activityId != null">activity_id = #{activityId},</if>
            <if test="jobType != null">job_type = #{jobType},</if>
            <if test="exportType != null">export_type = #{exportType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="generatedBy != null">generated_by = #{generatedBy},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            generated_at = sysdate()
        </set>
        where id = #{id}
    </update>
    <delete id="deleteExportJobById" parameterType="Long">delete from ExportJob where id = #{id}</delete>
    <delete id="deleteExportJobByIds" parameterType="Long">delete from ExportJob where id in <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>
